# ==========================================
# DEVGIZ - MASTER ENVIRONMENT CONFIGURATION
# ==========================================

# 1. SUPABASE (Autenticación y Almacenamiento de Archivos)
# Obtén estos valores en: Supabase Dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key-publica"
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key-secreta" # ¡NUNCA pongas esto en Vercel, solo en Render!

# 2. NEON (Base de Datos Serverless Premium)
# Obtén esto en: Neon Dashboard -> Connection Details
# Formato: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL="postgresql://devgiz_user:password@ep-cool-snowflake-1234.us-east-2.aws.neon.tech/neondb?sslmode=require"

# 3. RENDER API (Tu procesador GIS en Python)
# Cuando despliegues en Render, te darán una URL. Vercel usará esta URL para mandarle datos.
NEXT_PUBLIC_GEOAPI_URL="https://devgiz-geo-api.onrender.com"
